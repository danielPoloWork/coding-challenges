#!/bin/sh
# Regenerate generated index/manifest files before every commit so they
# always reflect the current set of solved challenges:
#   - stats/index-*.md        (Python, scripts/gen_indexes.py)
#   - README.md STATS block   (Python, scripts/gen_indexes.py) - live totals
#     banner kept in sync between the <!--STATS:BEGIN/END--> markers.
#   - platforms/manifest.json (Node,   src/scripts/build-manifest.mjs) - the
#     index the website fetches at runtime.
#
# Enable once per clone with:
#     git config core.hooksPath scripts/hooks
#
# Stats are mandatory: if Python is missing or the generator fails, block the
# commit rather than allowing stale stats/*.md files into history.
set -e

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if command -v python >/dev/null 2>&1; then
    PY=python
elif command -v python3 >/dev/null 2>&1; then
    PY=python3
elif command -v py >/dev/null 2>&1; then
    PY=py
else
    echo "pre-commit: Python is required to regenerate stats/*.md; aborting commit" >&2
    exit 1
fi

"$PY" scripts/gen_indexes.py
# Stage generated stats (including stale index deletions), the README banner
# block, and the per-asset ?v=<hash> cache-busts gen_indexes.py refreshes in the
# HTML so browsers always fetch fresh JS/CSS after a deploy.
git add -- stats README.md index.html src/*.html

# Regenerate the website manifest and compile JSX → JS (Node 18+). A missing
# Node interpreter is non-fatal; generator errors block the commit.
if command -v node >/dev/null 2>&1; then
    node src/scripts/build-manifest.mjs
    git add -- platforms/manifest.json
    node scripts/build-jsx.mjs
    # Stage compiled JS (all .js siblings of .jsx sources)
    git add -- src/assets/*.js src/tweaks-panel.js
else
    echo "pre-commit: no Node interpreter found; skipping manifest + JSX compilation" >&2
fi

exit 0
