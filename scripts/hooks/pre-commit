#!/bin/sh
# Regenerate the stats index files before every commit so they always reflect
# the current set of solved challenges.
#
# Enable once per clone with:
#     git config core.hooksPath scripts/hooks
#
# A missing Python interpreter is treated as non-fatal (the commit proceeds and
# the indexes are simply left untouched); a generator error blocks the commit so
# malformed metadata is noticed.
set -e

repo_root=$(git rev-parse --show-toplevel)

if command -v python >/dev/null 2>&1; then
    PY=python
elif command -v py >/dev/null 2>&1; then
    PY=py
else
    echo "pre-commit: no Python interpreter found; skipping index regeneration" >&2
    exit 0
fi

"$PY" "$repo_root/scripts/gen_indexes.py"

# Stage any (re)generated index files so they ride along with this commit.
git add "$repo_root/stats/"index-*.md 2>/dev/null || true

exit 0
